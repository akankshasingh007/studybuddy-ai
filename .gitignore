# Create .gitignore in your project folder
cat > .gitignore << 'EOF'
# Environment variables
.env
.env.local
.env.*.local

# Database
db.sqlite3
*.db

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
venv/
env/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Django
staticfiles/
media/
*.sqlite3
EOF